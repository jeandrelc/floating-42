generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  spotifyId     String?   @unique
  isAdmin       Boolean   @default(false)

  accounts Account[]
  sessions Session[]
  votes    Vote[]
}

model Week {
  id          String   @id @default(cuid())
  number      Int      @unique
  theme       String
  playlistId  String?
  startDate   DateTime
  endDate     DateTime
  votingOpen  Boolean  @default(false)
  winnerId    String?

  songs Song[]
  votes Vote[]
}

model Song {
  id             String  @id @default(cuid())
  weekId         String
  spotifyTrackId String
  addedByName      String
  addedBySpotifyId String?
  addedByImage     String?
  trackName        String?
  artistNames    String?
  albumImageUrl  String?
  spotifyUrl     String?
  energy         Float?
  danceability   Float?
  valence        Float?
  tempo          Float?
  acousticness   Float?
  tags           String?

  week  Week   @relation(fields: [weekId], references: [id])
  votes Vote[]
}

model Vote {
  id     String @id @default(cuid())
  weekId String
  userId String
  songId String

  week Week @relation(fields: [weekId], references: [id])
  user User @relation(fields: [userId], references: [id])
  song Song @relation(fields: [songId], references: [id])

  @@unique([weekId, userId])
}
